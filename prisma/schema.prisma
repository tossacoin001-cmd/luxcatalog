generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  real_estate
  supercar
  yacht
  decor
  commercial
  lifestyle
  shortlet
  executive_services
}

enum ListingStatus {
  available
  under_offer
  sold
}

enum InquiryStatus {
  new
  in_progress
  closed
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled
}

enum PaymentProvider {
  stripe
  paystack
}

model Listing {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  category     Category
  description  String
  price        Decimal?
  priceDisplay String
  location     String
  country      String
  images       String[]
  specs        Json
  features     String[]
  status       ListingStatus @default(available)
  featured     Boolean       @default(false)

  // Dual-purpose: a supercar (or any asset) can be for sale AND available for
  // chauffeur-driven hire (Lux Drive) without needing a separate listing/category.
  hireAvailable   Boolean  @default(false)
  hireRatePerDay  Decimal?
  hireRateDisplay String?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  savedBy           SavedListing[]
  inquiries         Inquiry[]
  unavailableDates  UnavailableDate[]
  orderItems        OrderItem[]
}

// Manually blocked date ranges for shortlet listings (e.g. Aqua). Booking
// stays inquiry-based for v1 — this only powers the "unavailable" calendar
// state shown to guests, not a live payment/reservation system.
model UnavailableDate {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  note      String?
  createdAt DateTime @default(now())
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Inquiry {
  id        String        @id @default(uuid())
  listingId String?
  listing   Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  userId    String?
  name      String
  email     String
  phone     String?
  message   String
  status    InquiryStatus @default(new)

  // Populated for shortlet (Aqua) requests-to-book and Lux Drive/Escort/Arrival
  // date-bound service requests. Null for ordinary asset enquiries.
  checkIn  DateTime?
  checkOut DateTime?

  createdAt DateTime      @default(now())
}

// Single-row cache of the NGN->USD rate so the storefront currency toggle
// doesn't call a live FX API on every request. Refreshed by a scheduled job.
model FxRate {
  id        String   @id @default(uuid())
  base      String   @default("NGN")
  quote     String   @default("USD")
  rate      Decimal
  source    String?
  updatedAt DateTime @updatedAt
}

// Real cart + checkout + delivery for Interior Decor. Separate from the
// Listing/Inquiry "reserve with a holding deposit" pattern used by
// real estate/cars/jets/yachts, which stays inquiry-based.
model Order {
  id              String          @id @default(uuid())
  userId          String?
  email           String
  phone           String?
  currency        String          @default("NGN")
  subtotal        Decimal
  shippingFee     Decimal
  total           Decimal
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingCountry String
  paymentProvider PaymentProvider
  paymentRef      String?
  status          OrderStatus     @default(pending)
  items           OrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId     String
  listing       Listing @relation(fields: [listingId], references: [id])
  titleSnapshot String
  priceSnapshot Decimal
  quantity      Int     @default(1)
}
